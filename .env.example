# Copy to `.env` on the Spark and fill in. `.env` is gitignored — never commit a real token.
#   cp .env.example .env  &&  nano .env
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NGC base image tag — change if 25.05-py3 doesn't pull on your Spark (see README).
# NGC_TAG=25.06-py3

# Optional overrides (defaults live in code/config.py):
# GEN_BACKEND=vllm        # or: hf
# GPU_MEM_UTIL=0.90
